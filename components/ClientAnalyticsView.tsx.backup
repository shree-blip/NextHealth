'use client';

import { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import {
  LineChart, Line, BarChart, Bar, PieChart, Pie, Cell,
  XAxis, YAxis, CartesianGrid, Tooltip, Legend, ResponsiveContainer,
  RadarChart, PolarGrid, PolarAngleAxis, PolarRadiusAxis, Radar,
  AreaChart, Area
} from 'recharts';
import { TrendingUp, Phone, Globe, MapPin, Eye, Star, Loader2, Building2, ChevronDown, ArrowUpRight, ArrowDownRight } from 'lucide-react';
import { useSitePreferences } from '@/components/SitePreferencesProvider';

interface ClinicInfo {
  id: string;
  name: string;
  type: string;
  location: string;
}

interface ClinicSummary {
  totalClicks: number;
  totalImpressions: number;
  avgCtr: number;
  avgPosition: number;
  totalPhoneCalls: number;
  totalWebsiteClicks: number;
  totalDirectionRequests: number;
  totalActions: number;
  dataPoints: number;
}

interface ClinicDataPoint {
  date: string;
  clicks: number;
  impressions: number;
  ctr: number;
  position: number;
  calls: number;
  websiteClicks: number;
  directions: number;
  profileViews: number;
  reviews: number;
}

interface ClinicAnalytics {
  clinic: ClinicInfo;
  summary: ClinicSummary;
  data: ClinicDataPoint[];
}

interface MultiLocationResponse {
  clinics: ClinicAnalytics[];
  allLocations: {
    summary: ClinicSummary;
    data: (ClinicDataPoint & { clinicId: string })[];
  };
}

const COLORS = ['#10b981', '#3b82f6', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899', '#06b6d4', '#84cc16'];
const LOCATION_COLORS = ['#10b981', '#3b82f6', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899'];

export default function ClientAnalyticsView() {
  const { theme } = useSitePreferences();
  const isDark = theme === 'dark';
  const [multiData, setMultiData] = useState<MultiLocationResponse | null>(null);
  const [selectedClinic, setSelectedClinic] = useState<string>('all');
  const [loading, setLoading] = useState(true);
  const [showDropdown, setShowDropdown] = useState(false);

  useEffect(() => {
    fetchMultiLocationAnalytics();
  }, []);

  const fetchMultiLocationAnalytics = async () => {
    setLoading(true);
    try {
      const res = await fetch('/api/analytics/by-clinic');
      if (res.ok) {
        const data = await res.json();
        setMultiData(data);
      }
    } catch (err) {
      console.error('Failed to fetch multi-location analytics:', err);
    } finally {
      setLoading(false);
    }
  };

  if (loading) {
    return (
      <div className="flex items-center justify-center py-24">
        <Loader2 className="h-8 w-8 animate-spin text-emerald-500" />
      </div>
    );
  }

  if (!multiData || (multiData.clinics.length === 0 && multiData.allLocations.summary.dataPoints === 0)) {
    return (
      <div className={`rounded-2xl p-8 border text-center ${isDark ? 'bg-slate-800 border-slate-700' : 'bg-slate-50 border-slate-200'}`}>
        <TrendingUp className={`h-12 w-12 mx-auto mb-4 ${isDark ? 'text-slate-500' : 'text-slate-400'}`} />
        <h3 className={`text-xl font-bold mb-2 ${isDark ? 'text-white' : 'text-slate-900'}`}>No Analytics Data Yet</h3>
        <p className={isDark ? 'text-slate-400' : 'text-slate-600'}>
          Your admin will add Google Search Console and Google My Business data for your locations soon.
        </p>
      </div>
    );
  }

  const currentClinicData = selectedClinic === 'all'
    ? null
    : multiData.clinics.find(c => c.clinic.id === selectedClinic);

  const currentSummary = selectedClinic === 'all'
    ? multiData.allLocations.summary
    : currentClinicData?.summary || multiData.allLocations.summary;

  const currentData = selectedClinic === 'all'
    ? multiData.allLocations.data.map(d => ({
        ...d,
        date: new Date(d.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
      }))
    : (currentClinicData?.data || []).map(d => ({
        ...d,
        date: new Date(d.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
      }));

  // GMB breakdown for pie chart
  const gmbBreakdown = [
    { name: 'Phone Calls', value: currentSummary.totalPhoneCalls },
    { name: 'Website Clicks', value: currentSummary.totalWebsiteClicks },
    { name: 'Direction Requests', value: currentSummary.totalDirectionRequests },
  ].filter(item => item.value > 0);

  // Location comparison data for radar chart
  const radarData = multiData.clinics.length > 1 ? [
    { metric: 'Clicks', ...Object.fromEntries(multiData.clinics.map(c => [c.clinic.name, c.summary.totalClicks])) },
    { metric: 'Impressions', ...Object.fromEntries(multiData.clinics.map(c => [c.clinic.name, Math.round(c.summary.totalImpressions / 100)])) },
    { metric: 'Calls', ...Object.fromEntries(multiData.clinics.map(c => [c.clinic.name, c.summary.totalPhoneCalls])) },
    { metric: 'Web Clicks', ...Object.fromEntries(multiData.clinics.map(c => [c.clinic.name, c.summary.totalWebsiteClicks])) },
    { metric: 'Directions', ...Object.fromEntries(multiData.clinics.map(c => [c.clinic.name, c.summary.totalDirectionRequests])) },
  ] : [];

  // Location comparison bar data
  const locationComparisonData = multiData.clinics.map(c => ({
    name: c.clinic.name.length > 15 ? c.clinic.name.substring(0, 15) + '...' : c.clinic.name,
    fullName: c.clinic.name,
    clicks: c.summary.totalClicks,
    impressions: c.summary.totalImpressions,
    calls: c.summary.totalPhoneCalls,
    websiteClicks: c.summary.totalWebsiteClicks,
    directions: c.summary.totalDirectionRequests,
    ctr: parseFloat(c.summary.avgCtr.toFixed(2)),
  }));

  const selectedClinicName = selectedClinic === 'all'
    ? 'All Locations'
    : multiData.clinics.find(c => c.clinic.id === selectedClinic)?.clinic.name || 'All Locations';

  return (
    <div className="space-y-8">
      {/* Location Selector */}
      {multiData.clinics.length > 0 && (
        <div className="flex items-center justify-between flex-wrap gap-4">
          <div>
            <h2 className={`text-2xl font-black ${isDark ? 'text-white' : 'text-slate-900'}`}>Performance Analytics</h2>
            <p className={`text-sm mt-1 ${isDark ? 'text-slate-400' : 'text-slate-500'}`}>
              {multiData.clinics.length} location{multiData.clinics.length !== 1 ? 's' : ''} tracked
            </p>
          </div>
          <div className="relative">
            <button
              onClick={() => setShowDropdown(!showDropdown)}
              className={`flex items-center gap-3 px-5 py-3 rounded-2xl border font-bold text-sm transition-all ${
                isDark
                  ? 'bg-slate-800 border-slate-700 text-white hover:bg-slate-700'
                  : 'bg-white border-slate-200 text-slate-900 hover:bg-slate-50 shadow-sm'
              }`}
            >
              <Building2 className="h-4 w-4 text-emerald-500" />
              {selectedClinicName}
              <ChevronDown className={`h-4 w-4 transition-transform ${showDropdown ? 'rotate-180' : ''}`} />
            </button>
            <AnimatePresence>
              {showDropdown && (
                <motion.div
                  initial={{ opacity: 0, y: -10 }}
                  animate={{ opacity: 1, y: 0 }}
                  exit={{ opacity: 0, y: -10 }}
                  className={`absolute right-0 top-full mt-2 w-72 rounded-2xl border shadow-xl z-50 overflow-hidden ${
                    isDark ? 'bg-slate-800 border-slate-700' : 'bg-white border-slate-200'
                  }`}
                >
                  <button
                    onClick={() => { setSelectedClinic('all'); setShowDropdown(false); }}
                    className={`w-full px-5 py-3 text-left text-sm font-bold flex items-center gap-3 transition-colors ${
                      selectedClinic === 'all'
                        ? 'bg-emerald-500 text-black'
                        : isDark ? 'hover:bg-slate-700 text-slate-200' : 'hover:bg-slate-50 text-slate-800'
                    }`}
                  >
                    <Globe className="h-4 w-4" />
                    All Locations
                  </button>
                  {multiData.clinics.map((c, idx) => (
                    <button
                      key={c.clinic.id}
                      onClick={() => { setSelectedClinic(c.clinic.id); setShowDropdown(false); }}
                      className={`w-full px-5 py-3 text-left text-sm flex items-center gap-3 transition-colors ${
                        selectedClinic === c.clinic.id
                          ? 'bg-emerald-500 text-black font-bold'
                          : isDark ? 'hover:bg-slate-700 text-slate-200' : 'hover:bg-slate-50 text-slate-800'
                      }`}
                    >
                      <div className="h-3 w-3 rounded-full" style={{ backgroundColor: LOCATION_COLORS[idx % LOCATION_COLORS.length] }} />
                      <div>
                        <div className="font-bold">{c.clinic.name}</div>
                        <div className={`text-xs ${selectedClinic === c.clinic.id ? 'text-black/60' : isDark ? 'text-slate-400' : 'text-slate-500'}`}>{c.clinic.location} • {c.clinic.type}</div>
                      </div>
                    </button>
                  ))}
                </motion.div>
              )}
            </AnimatePresence>
          </div>
        </div>
      )}

      {/* Summary Cards */}
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <SummaryCard isDark={isDark} label="Total Clicks" value={currentSummary.totalClicks} icon={TrendingUp} color="blue" subtitle="From Google Search" />
        <SummaryCard isDark={isDark} label="Impressions" value={currentSummary.totalImpressions} icon={Eye} color="purple" subtitle={`Avg CTR: ${currentSummary.avgCtr.toFixed(2)}%`} />
        <SummaryCard isDark={isDark} label="Phone Calls" value={currentSummary.totalPhoneCalls} icon={Phone} color="orange" subtitle="From GMB Profile" />
        <SummaryCard isDark={isDark} label="Website Clicks" value={currentSummary.totalWebsiteClicks} icon={Globe} color="emerald" subtitle="GMB Action" />
      </div>

      {/* Multi-Location Comparison Cards (only show when viewing all + multiple clinics) */}
      {selectedClinic === 'all' && multiData.clinics.length > 1 && (
        <div>
          <h3 className={`text-lg font-bold mb-4 ${isDark ? 'text-white' : 'text-slate-900'}`}>Location Performance Breakdown</h3>
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {multiData.clinics.map((c, idx) => (
              <motion.div
                key={c.clinic.id}
                initial={{ opacity: 0, y: 10 }}
                animate={{ opacity: 1, y: 0 }}
                transition={{ delay: idx * 0.1 }}
                onClick={() => setSelectedClinic(c.clinic.id)}
                className={`rounded-2xl p-6 border cursor-pointer transition-all hover:shadow-lg hover:scale-[1.02] ${
                  isDark ? 'bg-slate-800 border-slate-700 hover:border-emerald-500/50' : 'bg-white border-slate-200 hover:border-emerald-500/50'
                }`}
              >
                <div className="flex items-center gap-3 mb-4">
                  <div
                    className="h-10 w-10 rounded-xl flex items-center justify-center text-white font-bold text-sm"
                    style={{ backgroundColor: LOCATION_COLORS[idx % LOCATION_COLORS.length] }}
                  >
                    {c.clinic.name.substring(0, 2).toUpperCase()}
                  </div>
                  <div>
                    <h4 className={`font-bold text-sm ${isDark ? 'text-white' : 'text-slate-900'}`}>{c.clinic.name}</h4>
                    <p className={`text-xs ${isDark ? 'text-slate-400' : 'text-slate-500'}`}>{c.clinic.location}</p>
                  </div>
                </div>
                <div className="grid grid-cols-2 gap-3">
                  <MiniStat label="Clicks" value={c.summary.totalClicks} isDark={isDark} />
                  <MiniStat label="Impressions" value={c.summary.totalImpressions} isDark={isDark} />
                  <MiniStat label="Calls" value={c.summary.totalPhoneCalls} isDark={isDark} />
                  <MiniStat label="Web Clicks" value={c.summary.totalWebsiteClicks} isDark={isDark} />
                </div>
                <div className="mt-4 flex items-center gap-2 text-emerald-500 text-xs font-bold">
                  <span>View details</span>
                  <ArrowUpRight className="h-3 w-3" />
                </div>
              </motion.div>
            ))}
          </div>
        </div>
      )}

      {/* Charts Grid */}
      {currentData.length > 0 && (
        <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
          {/* Clicks & Impressions Trend */}
          <motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} className={`rounded-2xl p-6 border ${isDark ? 'bg-slate-800 border-slate-700' : 'bg-white border-slate-200'}`}>
            <h3 className={`text-lg font-bold mb-6 ${isDark ? 'text-white' : 'text-slate-900'}`}>
              Google Search Console Trend
              {selectedClinic !== 'all' && <span className="text-sm font-normal text-slate-500 ml-2">— {selectedClinicName}</span>}
            </h3>
            <ResponsiveContainer width="100%" height={300}>
              <AreaChart data={currentData}>
                <defs>
                  <linearGradient id="colorClicks" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="5%" stopColor="#3b82f6" stopOpacity={0.3}/>
                    <stop offset="95%" stopColor="#3b82f6" stopOpacity={0}/>
                  </linearGradient>
                  <linearGradient id="colorImpressions" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="5%" stopColor="#10b981" stopOpacity={0.3}/>
                    <stop offset="95%" stopColor="#10b981" stopOpacity={0}/>
                  </linearGradient>
                </defs>
                <CartesianGrid strokeDasharray="3 3" stroke={isDark ? '#475569' : '#e5e7eb'} />
                <XAxis dataKey="date" fontSize={12} stroke={isDark ? '#cbd5e1' : '#000'} />
                <YAxis fontSize={12} stroke={isDark ? '#cbd5e1' : '#000'} />
                <Tooltip contentStyle={{ backgroundColor: isDark ? '#1e293b' : '#fff', border: isDark ? '1px solid #475569' : '1px solid #e5e7eb', borderRadius: '12px', color: isDark ? '#e2e8f0' : '#000' }} />
                <Legend />
                <Area type="monotone" dataKey="clicks" stroke="#3b82f6" strokeWidth={2} fill="url(#colorClicks)" name="Clicks" />
                <Area type="monotone" dataKey="impressions" stroke="#10b981" strokeWidth={2} fill="url(#colorImpressions)" name="Impressions" />
              </AreaChart>
            </ResponsiveContainer>
          </motion.div>

          {/* CTR & Position Trend */}
          <motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: 0.1 }} className={`rounded-2xl p-6 border ${isDark ? 'bg-slate-800 border-slate-700' : 'bg-white border-slate-200'}`}>
            <h3 className={`text-lg font-bold mb-6 ${isDark ? 'text-white' : 'text-slate-900'}`}>Click-Through Rate & Position</h3>
            <ResponsiveContainer width="100%" height={300}>
              <LineChart data={currentData}>
                <CartesianGrid strokeDasharray="3 3" stroke={isDark ? '#475569' : '#e5e7eb'} />
                <XAxis dataKey="date" fontSize={12} stroke={isDark ? '#cbd5e1' : '#000'} />
                <YAxis yAxisId="left" fontSize={12} stroke={isDark ? '#cbd5e1' : '#000'} />
                <YAxis yAxisId="right" orientation="right" fontSize={12} stroke={isDark ? '#cbd5e1' : '#000'} />
                <Tooltip contentStyle={{ backgroundColor: isDark ? '#1e293b' : '#fff', border: isDark ? '1px solid #475569' : '1px solid #e5e7eb', borderRadius: '12px', color: isDark ? '#e2e8f0' : '#000' }} />
                <Legend />
                <Line yAxisId="left" type="monotone" dataKey="ctr" stroke="#f59e0b" strokeWidth={2} dot={false} name="CTR (%)" />
                <Line yAxisId="right" type="monotone" dataKey="position" stroke="#ef4444" strokeWidth={2} dot={false} name="Avg Position" />
              </LineChart>
            </ResponsiveContainer>
          </motion.div>
        </div>
      )}

      {/* GMB Breakdown + Location Comparison */}
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {/* GMB Actions Pie Chart */}
        {gmbBreakdown.length > 0 && (
          <motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} className={`rounded-2xl p-6 border ${isDark ? 'bg-slate-800 border-slate-700' : 'bg-white border-slate-200'}`}>
            <h3 className={`text-lg font-bold mb-6 ${isDark ? 'text-white' : 'text-slate-900'}`}>GMB Actions Breakdown</h3>
            <ResponsiveContainer width="100%" height={300}>
              <PieChart>
                <Pie
                  data={gmbBreakdown}
                  cx="50%"
                  cy="50%"
                  innerRadius={60}
                  outerRadius={100}
                  labelLine={false}
                  label={({ name, value }) => `${name}: ${value}`}
                  fill="#8884d8"
                  dataKey="value"
                >
                  {gmbBreakdown.map((entry, index) => (
                    <Cell key={`cell-${index}`} fill={COLORS[index % COLORS.length]} />
                  ))}
                </Pie>
                <Tooltip contentStyle={{ backgroundColor: isDark ? '#1e293b' : '#fff', border: isDark ? '1px solid #475569' : 'none', borderRadius: '12px', color: isDark ? '#e2e8f0' : '#000' }} />
              </PieChart>
            </ResponsiveContainer>
          </motion.div>
        )}

        {/* GMB Actions Over Time */}
        {currentData.length > 0 && (
          <motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: 0.1 }} className={`rounded-2xl p-6 border ${isDark ? 'bg-slate-800 border-slate-700' : 'bg-white border-slate-200'}`}>
            <h3 className={`text-lg font-bold mb-6 ${isDark ? 'text-white' : 'text-slate-900'}`}>GMB Actions Over Time</h3>
            <ResponsiveContainer width="100%" height={300}>
              <BarChart data={currentData}>
                <CartesianGrid strokeDasharray="3 3" stroke={isDark ? '#475569' : '#e5e7eb'} />
                <XAxis dataKey="date" fontSize={12} stroke={isDark ? '#cbd5e1' : '#000'} />
                <YAxis fontSize={12} stroke={isDark ? '#cbd5e1' : '#000'} />
                <Tooltip contentStyle={{ backgroundColor: isDark ? '#1e293b' : '#fff', border: isDark ? '1px solid #475569' : 'none', borderRadius: '12px', color: isDark ? '#e2e8f0' : '#000' }} />
                <Legend />
                <Bar dataKey="calls" fill="#f59e0b" name="Phone Calls" radius={[4, 4, 0, 0]} />
                <Bar dataKey="websiteClicks" fill="#3b82f6" name="Website Clicks" radius={[4, 4, 0, 0]} />
                <Bar dataKey="directions" fill="#10b981" name="Directions" radius={[4, 4, 0, 0]} />
              </BarChart>
            </ResponsiveContainer>
          </motion.div>
        )}
      </div>

      {/* Multi-Location Comparison Charts (only when viewing all + multiple clinics) */}
      {selectedClinic === 'all' && multiData.clinics.length > 1 && (
        <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
          {/* Location Performance Comparison Bar Chart */}
          <motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} className={`rounded-2xl p-6 border ${isDark ? 'bg-slate-800 border-slate-700' : 'bg-white border-slate-200'}`}>
            <h3 className={`text-lg font-bold mb-6 ${isDark ? 'text-white' : 'text-slate-900'}`}>Location Comparison — Clicks & Calls</h3>
            <ResponsiveContainer width="100%" height={300}>
              <BarChart data={locationComparisonData} layout="vertical">
                <CartesianGrid strokeDasharray="3 3" stroke={isDark ? '#475569' : '#e5e7eb'} />
                <XAxis type="number" fontSize={12} stroke={isDark ? '#cbd5e1' : '#000'} />
                <YAxis type="category" dataKey="name" fontSize={11} width={120} stroke={isDark ? '#cbd5e1' : '#000'} />
                <Tooltip contentStyle={{ backgroundColor: isDark ? '#1e293b' : '#fff', border: isDark ? '1px solid #475569' : 'none', borderRadius: '12px', color: isDark ? '#e2e8f0' : '#000' }} />
                <Legend />
                <Bar dataKey="clicks" fill="#3b82f6" name="Clicks" radius={[0, 4, 4, 0]} />
                <Bar dataKey="calls" fill="#f59e0b" name="Calls" radius={[0, 4, 4, 0]} />
                <Bar dataKey="websiteClicks" fill="#10b981" name="Web Clicks" radius={[0, 4, 4, 0]} />
              </BarChart>
            </ResponsiveContainer>
          </motion.div>

          {/* Radar Chart comparing locations */}
          {radarData.length > 0 && (
            <motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: 0.1 }} className={`rounded-2xl p-6 border ${isDark ? 'bg-slate-800 border-slate-700' : 'bg-white border-slate-200'}`}>
              <h3 className={`text-lg font-bold mb-6 ${isDark ? 'text-white' : 'text-slate-900'}`}>Location Performance Radar</h3>
              <ResponsiveContainer width="100%" height={300}>
                <RadarChart data={radarData}>
                  <PolarGrid stroke={isDark ? '#475569' : '#e5e7eb'} />
                  <PolarAngleAxis dataKey="metric" fontSize={12} stroke={isDark ? '#cbd5e1' : '#000'} />
                  <PolarRadiusAxis fontSize={10} stroke={isDark ? '#cbd5e1' : '#94a3b8'} />
                  {multiData.clinics.map((c, idx) => (
                    <Radar
                      key={c.clinic.id}
                      name={c.clinic.name}
                      dataKey={c.clinic.name}
                      stroke={LOCATION_COLORS[idx % LOCATION_COLORS.length]}
                      fill={LOCATION_COLORS[idx % LOCATION_COLORS.length]}
                      fillOpacity={0.15}
                      strokeWidth={2}
                    />
                  ))}
                  <Legend />
                  <Tooltip contentStyle={{ backgroundColor: isDark ? '#1e293b' : '#fff', border: isDark ? '1px solid #475569' : 'none', borderRadius: '12px', color: isDark ? '#e2e8f0' : '#000' }} />
                </RadarChart>
              </ResponsiveContainer>
            </motion.div>
          )}
        </div>
      )}

      {/* Detailed Metrics Table */}
      {currentData.length > 0 && (
        <motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} transition={{ delay: 0.2 }} className={`rounded-2xl p-6 border ${isDark ? 'bg-slate-800 border-slate-700' : 'bg-white border-slate-200'} overflow-x-auto`}>
          <h3 className={`text-lg font-bold mb-6 ${isDark ? 'text-white' : 'text-slate-900'}`}>
            Detailed Analytics
            {selectedClinic !== 'all' && <span className="text-sm font-normal text-slate-500 ml-2">— {selectedClinicName}</span>}
          </h3>
          <table className="w-full text-sm">
            <thead>
              <tr className={`border-b ${isDark ? 'border-slate-700' : 'border-slate-200'}`}>
                <th className={`text-left py-3 px-4 font-bold ${isDark ? 'text-slate-300' : 'text-slate-700'}`}>Date</th>
                <th className={`text-right py-3 px-4 font-bold ${isDark ? 'text-slate-300' : 'text-slate-700'}`}>Clicks</th>
                <th className={`text-right py-3 px-4 font-bold ${isDark ? 'text-slate-300' : 'text-slate-700'}`}>Impressions</th>
                <th className={`text-right py-3 px-4 font-bold ${isDark ? 'text-slate-300' : 'text-slate-700'}`}>CTR</th>
                <th className={`text-right py-3 px-4 font-bold ${isDark ? 'text-slate-300' : 'text-slate-700'}`}>Position</th>
                <th className={`text-right py-3 px-4 font-bold ${isDark ? 'text-slate-300' : 'text-slate-700'}`}>Calls</th>
                <th className={`text-right py-3 px-4 font-bold ${isDark ? 'text-slate-300' : 'text-slate-700'}`}>Website</th>
                <th className={`text-right py-3 px-4 font-bold ${isDark ? 'text-slate-300' : 'text-slate-700'}`}>Directions</th>
              </tr>
            </thead>
            <tbody>
              {currentData.map((row, idx) => (
                <tr key={idx} className={`border-b transition-colors ${isDark ? 'border-slate-700 hover:bg-slate-700' : 'border-slate-100 hover:bg-slate-50'}`}>
                  <td className={`py-3 px-4 font-semibold ${isDark ? 'text-slate-300' : 'text-slate-900'}`}>{row.date}</td>
                  <td className={`text-right py-3 px-4 font-semibold ${isDark ? 'text-blue-400' : 'text-blue-600'}`}>{row.clicks.toLocaleString()}</td>
                  <td className={`text-right py-3 px-4 font-semibold ${isDark ? 'text-purple-400' : 'text-purple-600'}`}>{row.impressions.toLocaleString()}</td>
                  <td className={`text-right py-3 px-4 font-semibold ${isDark ? 'text-orange-400' : 'text-orange-600'}`}>{parseFloat((row.ctr || 0).toFixed(2))}%</td>
                  <td className={`text-right py-3 px-4 font-semibold ${isDark ? 'text-red-400' : 'text-red-600'}`}>{parseFloat((row.position || 0).toFixed(1))}</td>
                  <td className={`text-right py-3 px-4 font-semibold ${isDark ? 'text-orange-400' : 'text-orange-600'}`}>{row.calls}</td>
                  <td className={`text-right py-3 px-4 font-semibold ${isDark ? 'text-emerald-400' : 'text-emerald-600'}`}>{row.websiteClicks}</td>
                  <td className={`text-right py-3 px-4 font-semibold ${isDark ? 'text-cyan-400' : 'text-cyan-600'}`}>{row.directions}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </motion.div>
      )}
    </div>
  );
}

/* ─── Helper Components ─── */
function SummaryCard({ isDark, label, value, icon: Icon, color, subtitle }: {
  isDark: boolean;
  label: string;
  value: number;
  icon: any;
  color: 'blue' | 'purple' | 'orange' | 'emerald';
  subtitle: string;
}) {
  const colorMap = {
    blue: {
      bg: isDark ? 'bg-blue-900/30 border-blue-800' : 'bg-gradient-to-br from-blue-50 to-cyan-50 border-blue-200',
      text: isDark ? 'text-blue-300' : 'text-blue-700',
      label: isDark ? 'text-blue-300' : 'text-slate-600',
      icon: 'text-blue-500',
    },
    purple: {
      bg: isDark ? 'bg-purple-900/30 border-purple-800' : 'bg-gradient-to-br from-purple-50 to-pink-50 border-purple-200',
      text: isDark ? 'text-purple-300' : 'text-purple-700',
      label: isDark ? 'text-purple-300' : 'text-slate-600',
      icon: 'text-purple-500',
    },
    orange: {
      bg: isDark ? 'bg-orange-900/30 border-orange-800' : 'bg-gradient-to-br from-orange-50 to-yellow-50 border-orange-200',
      text: isDark ? 'text-orange-300' : 'text-orange-700',
      label: isDark ? 'text-orange-300' : 'text-slate-600',
      icon: 'text-orange-500',
    },
    emerald: {
      bg: isDark ? 'bg-emerald-900/30 border-emerald-800' : 'bg-gradient-to-br from-emerald-50 to-teal-50 border-emerald-200',
      text: isDark ? 'text-emerald-300' : 'text-emerald-700',
      label: isDark ? 'text-emerald-300' : 'text-slate-600',
      icon: 'text-emerald-500',
    },
  };
  const c = colorMap[color];

  return (
    <motion.div initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }} className={`rounded-2xl p-6 border ${c.bg}`}>
      <div className="flex items-center justify-between mb-2">
        <span className={`text-sm font-bold ${c.label}`}>{label}</span>
        <Icon className={`h-5 w-5 ${c.icon}`} />
      </div>
      <div className={`text-3xl font-black ${c.text}`}>{value.toLocaleString()}</div>
      <p className={`text-xs mt-2 ${isDark ? 'opacity-60' : 'text-slate-500'}`}>{subtitle}</p>
    </motion.div>
  );
}

function MiniStat({ label, value, isDark }: { label: string; value: number; isDark: boolean }) {
  return (
    <div>
      <div className={`text-xs ${isDark ? 'text-slate-400' : 'text-slate-500'}`}>{label}</div>
      <div className={`text-lg font-black ${isDark ? 'text-white' : 'text-slate-900'}`}>{value.toLocaleString()}</div>
    </div>
  );
}
